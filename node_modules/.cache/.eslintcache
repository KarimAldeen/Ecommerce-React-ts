ton>}\n// >\n//   {/* Your content goes here */}\n// </WithDrawer>","/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/CardItem.tsx",["825","826","827"],[],"import {  CloseOutlined, MinusCircleOutlined, PlusCircleFilled } from '@ant-design/icons';\nimport React, { useState } from 'react';\nimport {  Card, Skeleton, Switch ,Popconfirm,Button, Tooltip} from 'antd';\nimport useLoadingState from '../../Hooks/useLoadingState';\nimport { TProduct } from '../../Layout/app/Types';\n\n\ninterface CartItemProps {\n  item: TProduct;\n  index : number ;\n}\nconst CardItem: React.FC  = () => {\n  const [loading, resetLoading] = useLoadingState(true, 2000);\n  const [Counter, setCounter] = useState<number>(1);\n  const [Price, setPrice] = useState<number>(210);\n\n  return (\n    <>\n      <Skeleton loading={loading} active avatar  style={{ width: 340, marginTop: 22 }}>\n      <Card className='CardItem'  style={{ width: 330, marginTop: 16 }} loading={loading}>\n      <span className='Card_Counter'>\n        <Button  shape=\"circle\" icon={<PlusCircleFilled />} onClick={()=>{setCounter(v => ++v) ; setPrice(v=> 2 * v )} } />\n        <div className='Counter'>\n          {Counter}\n        </div>\n        <Button  shape=\"circle\" icon={<MinusCircleOutlined />} onClick={()=>{setCounter(v => v > 1 ? --v : v) ;setPrice(v=> Counter > 1 ? v/2 : v )}} />\n      </span>\n      <span className='Card_Img'>\n      <img alt=''  src='../Product/Product.png'   />\n      </span>\n      <span className='Card_Info'>\n        <h5> Silver High Neck Sweater </h5>\n        <h6>  Neck Sweater </h6>\n        <strong> ${Price}.00 </strong>\n      </span>\n      <span className='Card_Delete'>\n      <Popconfirm\n    title=\"Delete the Item\"\n    description=\"Are you sure to delete this Item?\"\n    okText=\"Yes\"\n    cancelText=\"No\"\n  >\n      <Tooltip title=\"Delete\" placement=\"bottom\" >\n\n    <Button shape=\"circle\" icon={<CloseOutlined />}  danger/>\n    </Tooltip>\n\n  </Popconfirm>\n      </span>\n      </Card>\n      </Skeleton>\n\n    </>\n  );\n};\n\nexport default CardItem;","/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/DropdownMenu.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/NavBar/BottomBar.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/MenuItems.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/MenuItemsData.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/DropDown.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/NavBar/NavBar.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Ui/Carousel.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/HeroSection.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/SpecialProperties.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/MovesAds.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/SubTitle.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Utils/BombBtn/BombBtn.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/CardSwiper.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/CardProduct.tsx",["828","829","830"],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Home/ProductSection.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Layout/app/Types.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Hooks/useLoadingState.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Layout/app/Footer.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Layout/app/Layout.tsx",[],[],"/home/karim/De