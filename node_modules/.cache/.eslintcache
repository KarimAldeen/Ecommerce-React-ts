lusSquareOutlined } from '@ant-design/icons';\nimport React, { useState } from 'react';\nimport {  Card, Skeleton ,Popconfirm,Button, Tooltip} from 'antd';\nimport useLoadingState from '../../Hooks/useLoadingState';\nimport { TProduct } from '../../Layout/app/Types';\nimport { Currency } from '../../Layout/app/Const';\n\n\n\ninterface CartItemProps {\n  item: TProduct;\n}\nconst CartItem: React.FC <CartItemProps> = ({item}) => {\n  const [loading, resetLoading] = useLoadingState(true, 2000);\n  const [Counter, setCounter] = useState<number>(1);\n  const [Price, setPrice] = useState<number>(210);\n\n  return (\n    <div className='CartItem'>\n      <Skeleton loading={loading} active avatar  style={{ marginTop: 22 }}>\n      <Card loading={loading}>\n   \n      <span className='Cart_Img'>\n      <img alt=''  src='../Product/Product.png'   />\n      </span>\n      <span className='Cart_Info'>\n        <h5> Silver High Neck Sweater </h5>\n        <h6>  Neck Sweater </h6>\n        <strong> {Currency}{Price}.00 </strong> \n      </span>\n      <span className='Cart_Counter'>\n        <Button  shape=\"circle\" icon={<PlusSquareOutlined />} onClick={()=>{setCounter(v => ++v) ; setPrice(v=> 2 * v )} } />\n        <div className='Counter'>\n          {Counter}\n        </div>\n        <Button  shape=\"circle\" icon={<MinusSquareOutlined />} onClick={()=>{setCounter(v => v > 1 ? --v : v) ;setPrice(v=> Counter > 1 ? v/2 : v )}} />\n      </span>\n      <span className='Cart_Delete'>\n      <Popconfirm\n    title=\"Delete the Item\"\n    description=\"Are you sure to delete this Item?\"\n    okText=\"Yes\"\n    cancelText=\"No\"\n  >\n      <Tooltip title=\"Delete\" placement=\"bottom\" >\n\n    <Button shape=\"circle\" icon={<CloseOutlined />}  danger/>\n    </Tooltip>\n\n  </Popconfirm>\n      </span>\n      </Card>\n      </Skeleton>\n\n    </div>\n  );\n};\n\nexport default CartItem;","/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/HighOrderComponent/WithFormik.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Details/DetailsBody.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Details/DetailsForm.tsx",["876"],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Payment/PaymentBody.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Payment/PaymentForm.tsx",[],["877","878","879","880","881","882","883","884","885","886","887","888","889","890"],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Review/ReviewBody.tsx",["891"],[],"/home/karim/Desktop/Karim/Code/React/Ecommerce-React-ts/src/Components/Cart/Review/ReviewForm.tsx",["892","893","894","895"],["896","897","898","899","900","901","902","903","904","905","906","907","908","909"],{"ruleId":"910","replacedBy":"911"},{"ruleId":"912","severity":1,"message":"913","line":9,"column":10,"nodeType":"914","messageId":"915","endLine":9,"endColumn":23},{"ruleId":"910","replacedBy":"916"},{"ruleId":"912","severity":1,"message":"917","line":7,"column":10,"nodeType":"914","messageId":"915","endLine":7,"endColumn":18},{"ruleId":"912","severity":1,"message":"918","line":2,"column":8,"nodeType":"914","messageId":"915","endLine":2,"endColumn":16},{"ruleId":"919","severity":1,"message":"920","line":40,"column":53,"nodeType":"914","messageId":"921","endLine":40,"endColumn":57,"suppressions":"922"},{"ruleId":"919","severity":1,"message":"920","line":40,"column":94,"nodeType":"914","messageId":"921","endLine":40,"endColumn":98,"suppressions":"923"},{"ruleId":"924","severity":2,"message":"925","line":40,"column":37715,"nodeType":"926","messageId":"927","endLine":40,"endColumn":37721,"suppressions":"928"},{"ruleId":"924","severity":2,"message":"925","line":40,"column":37810,"nodeType":"926","messageId":"927","endLine":40,"endColumn":37816,"suppressions":"929"},{"ruleId":"924","severity":2,"message":"925","line":40,"column":3787