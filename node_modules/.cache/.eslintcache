olor,\r\n            color:text\r\n          }\r\n        }\r\n      }}\r\n      progressComponent={<Spinner />}\r\n      {...props}\r\n      />\r\n    \r\n    </CardBody>\r\n  </Card>\r\n  )\r\n}\r\n\r\nexport default LyTable","/home/karim/Desktop/Karim/Code/React/MyDashboard/src/Layout/Dashboard/DashBody.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/index.tsx",[],[],["752"],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/ProviderContainer.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/App.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Routes.tsx",["753"],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/lib/ReactQueryProvider.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/lib/ToastProvider.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/app/NotFoundPage.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/app/Layout.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Auth/Page.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Components/Utils/Loading/Loading.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Example2/Page.tsx",["754"],["755","756","757","758","759","760","761","762","763","764","765","766","767"],"import React from 'react'\nimport DashBody from '../../Layout/Dashboard/DashBody'\nimport DashHeader from '../../Layout/Dashboard/DashHeader'\nimport LyTable from '../../Layout/Dashboard/LyTable'\nimport useTableColumns from './useTableColumns'\nimport EditExampleModal from './EditExampleModal'\nimport AddExampleModal from './AddExampleModal'\nimport { useGetDynamic } from '../../api/Route/Get'\n\nfunction Page() {\n\n    const column   =useTableColumns()\n    const {data} = useGetDynamic(\"users\")\n  /* eslint-disable */console.log(...oo_oo(`1395695632_14_2_14_19_4`,data));\n  \n    \n  return (\n