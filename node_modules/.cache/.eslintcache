e='SideBar_Top'>\n        <div onClick={()=>Onimg()}>\n          <KarimLogo/>\n        </div>\n        <div className='HamburgerMenu' onClick={()=> OnHamburgerMenu()} >\n          <GiHamburgerMenu />\n\n        </div>\n\n      </div>\n      <div className='RoutesLinks'>\n        {\n          RoutesLinks?.map((i:any, index:number) => {\n            const isActive = pathname === i?.href;\n\n            if (i?.href) {\n              return (\n        \n                  <Link\n                    to={i?.href}\n                    className={isActive ? 'SideBar_Link Active_SideBar_Link' : 'SideBar_Link'}\n                    key={index}\n                  >\n                    {(i?.icon )}\n                    <div className='Link_Text'>\n                      {t(`${i?.name}`)}\n\n                    </div>\n                  </Link>\n\n              )\n            }\n            else {\n              return (\n                <React.Fragment key={index} >\n                  <div\n                  onClick={() => setIsopen(v => !v)}\n                    className={Isopen ? 'SideBar_Link DropDown  DropDown_SideBar_Link' : 'SideBar_Link DropDown'}\n                    key={index}\n\n                  >\n                    <div >\n                    {i?.icon}\n                    </div>\n                    \n                    <div className='DropDown_Text'>\n                      {t(`${i?.name}`)}\n\n                    </div>\n                    <div className='DropDown_Svg' >\n                     {Isopen ? <FaAngleDown /> :  <FaAngleRight />\n\n                     }\n\n                    </div>\n                  </div>\n                  {Isopen ?\n\n                    i?.children?.map((i:any, index:number) => {\n                      if (i?.href) {\n                        return (\n                          <React.Fragment key={index}>\n                            <Link\n                              to={i?.href}\n                              className={'SideBar_Link'}\n                            >\n                              {i?.icon}\n                              <div className='Link_Text'>\n                              {t(`${i?.name}`)}\n\n                              </div>\n                            </Link>\n\n                          </React.Fragment>\n\n                        )\n                      }\n                      return null\n                    }\n\n                    )\n                    : \"\"\n\n                  }\n                </React.Fragment>\n\n              )\n            }\n\n          })\n        }\n\n\n\n      </div>\n    </div>\n  )\n}\n\nexport default SideBar","/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/config/AppKey.ts",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/app/Header.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Auth/LoginForm.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/app/Const.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/api/example.ts",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Example2/useTableColumns.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Example2/EditExampleModal.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Pages/Example2/AddExampleModal.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/Dashboard/DashBody.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/Dashboard/DashHeader.tsx",[],[],"/home/karim/Desktop/Karim/Code/React/Dashboard-React-ts/src/Layout/Dashboard/LyTable.tsx",["769"],[],"\r\nimport DataTable from 'react-data-table-component';\r\nimport { Card, CardBody, Spinner } from 'reactstrap';\r\nimport { usePageState } from '../../lib/state';\r\n\r\nconst LyTable = (props:any) => {\r\n\r\n  // Important this line for rerender is the them has been changed\r\